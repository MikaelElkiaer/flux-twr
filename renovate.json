{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ],
    "pinDigests": true
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ],
    "ignorePaths": [
      "bootstrap/**"
    ]
  }
}
