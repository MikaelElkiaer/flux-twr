{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ],
    "pinDigests": true
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ],
    "ignorePaths": [
      "bootstrap/**"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^system-upgrade/k3s/server\\.Plan\\.yaml$/"],
      "matchStrings": ["version: (?<currentValue>.*)"],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases"
    }
  ]
}
